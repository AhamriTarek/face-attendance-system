# Example environment variables. Copy to .env and fill real values.
# Do NOT commit the real .env.
#
# For LOCAL development with live face capture, also:
#   pip install -r requirements-local.txt
#   set FACE_RECOGNITION_ENABLED=True

# --- Core Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

# Cloud mode: live webcam face capture disabled (set True only on local dev).
FACE_RECOGNITION_ENABLED=False

# --- Database (MySQL) ---
DB_ENGINE=django.db.backends.mysql
DB_NAME=face_attendance_db
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
